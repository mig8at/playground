# Copia este archivo a .env y pon tus valores reales (el .env está en .gitignore).

# Bot token de tu Slack App — empieza con xoxb-. Es EL que necesita crear canales.
# Se obtiene en https://api.slack.com/apps -> tu app -> OAuth & Permissions -> Install to Workspace.
SLACK_BOT_TOKEN=xoxb-tu-token-aqui

# Canal de pruebas para el botón "enviar mensaje" del frontend (ID del canal, ej C0123ABCD).
SLACK_TEST_CHANNEL=

# Token PERSONAL (xoxp-) de TU propia Slack app, para enviar DMs "como tú".
# User Token Scopes: chat:write, im:write, users:read, users:read.email
SLACK_USER_TOKEN=

# App Credentials (Basic Information). Solo hacen falta si implementas el flujo OAuth2.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# ===== Atlassian / Jira Cloud (para el conector jira-mcp) =====
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_SITE=https://tu-sitio.atlassian.net
ATLASSIAN_EMAIL=tu-email@empresa.com
ATLASSIAN_API_TOKEN=
