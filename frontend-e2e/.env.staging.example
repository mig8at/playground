# ============================================================================
#  frontend-e2e · TARGET=staging   (E2E_TARGET=staging)
# ============================================================================
#  El FRONT es el DESPLEGADO de staging, pero la BD/API/APP_KEY son LAS MISMAS
#  que dev (staging comparte backend con dev). Por decisión, este archivo es
#  AUTOSUFICIENTE: los valores de BD/API/APP_KEY de abajo son COPIA de dev.
#  ⚠ Si rotan las credenciales de dev, actualizá dev Y staging.
#  Gitignoreado. Plantilla: .env.staging.example.
#  Guarda de escritura: igual que dev (se exporta a mano o la inyecta el panel).

# ── Base de datos · = dev (RDS COMPARTIDA — copia de dev) ──
E2E_DB_HOST=
E2E_DB_PORT=
E2E_DB_NAME=
E2E_DB_USER=
E2E_DB_PASS=

# ── API + cripto · = dev ──
E2E_API_BASE_URL=
APP_KEY=

# ── Frontend · DESPLEGADO de staging ──
E2E_BASE_URL=

# ── Pre-aprobaciones ──
E2E_REAL_PREAPPROVALS=

# ── Cognito · pool de STAGING (miguel-test) ──
# Reemplaza a oscar+dentix. miguel-test vive en el pool de staging (login validado).
E2E_COGNITO_USER=
E2E_COGNITO_PASS=
# sub de miguel-test EN STAGING. Casi seguro el que sigue (ya está en la fila de BD
# sobre Dentix); confirmalo con Oscar o con el sub-probe de staging.
E2E_ASESOR_SUB=
# Opcional — solo para el sub-probe DIRECTO contra staging (PKCE). El client_id lo
# tiene que dar Oscar; domain/redirect quedan inferidos:
#   E2E_COGNITO_DOMAIN=auth.merchant.creditop.com
#   E2E_COGNITO_CLIENT_ID=<pedir a Oscar>
#   E2E_COGNITO_REDIRECT=https://originaciones-stg.dev.creditop.com/auth/callback
