# ============================================================================
#  frontend-e2e · TARGET=staging   (E2E_TARGET=staging)
# ============================================================================
#  Front DESPLEGADO de staging; BD/API/APP_KEY son COPIA de dev (comparten backend).
#  ⚠ Si rotan las credenciales de dev, actualizá dev Y staging.
#  Gitignoreado. Plantilla: .env.staging.example.

# ── Base de datos · = dev (RDS COMPARTIDA — copia de dev) ──
E2E_DB_HOST=
E2E_DB_PORT=
E2E_DB_NAME=
E2E_DB_USER=
E2E_DB_PASS=

# ── API + cripto · = dev ──
E2E_API_BASE_URL=
APP_KEY=

# ── Frontend · DESPLEGADO de staging ──
E2E_BASE_URL=

# ── Pre-aprobaciones ──
E2E_REAL_PREAPPROVALS=

# ── Cognito · pool de STAGING (oscar+dentix) ──
#  oscar+dentix es la cuenta de staging que ANDA. La CONTRASEÑA va abajo y la ponés VOS
#  (queda vacía en el repo/archivo a propósito).
#  ⚠ miguel-test@creditop.com quedó PENDIENTE: su login NO se confirmó — Cognito rechaza la
#    contraseña (password123+) tanto en dev como en staging (2026-07-22). La "validación" previa
#    fue un FALSO POSITIVO: warm-session reusó una sesión ya cacheada (de oscar+dentix), no logueó
#    a miguel-test. Cuando Oscar confirme la clave/estado real de miguel-test, se hace el swap
#    (E2E_COGNITO_USER + E2E_ASESOR_SUB del pool que corresponda).
E2E_COGNITO_USER=
E2E_COGNITO_PASS=
# sub de oscar+dentix en el pool de staging
E2E_ASESOR_SUB=
