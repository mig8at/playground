    "ecommerce":    { "tool": "asesor", "merchant": "pullman", "flow": true, "ecommerce": true, "lender": "credipullman", "env": "local" },
    "asesor-local": { "tool": "asesor", "merchant": "pullman", "flow": true, "preview": true, "env": "local" },
    "asesor-dev":   { "tool": "asesor", "merchant": "pullman", "flow": true, "env": "dev" },
    "checkout":     { "tool": "checkout", "merchant": "pullman", "env": "dev" }
  }
