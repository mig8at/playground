{
  "_comment": "Presets de frontend-e2e (UI): fixtures (phone/otp/monto) + alias de merchant por entorno + scenarios. El WEBHOOK y el RETURN_URL NO viven acá: se setean en .env.local / .env.dev (E2E_WEBHOOK_URL / E2E_RETURN_URL). NO cachea la BD. Lo consume bin/scenario.",

  "defaults": {
    "phone": "3131010101",
    "otp": "0101",
    "amount": 600000
  },

