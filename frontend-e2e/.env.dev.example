# ============================================================================
#  frontend-e2e · TARGET=dev   (E2E_TARGET=dev — el default)
# ============================================================================
#  Prueba contra la infra REAL de dev: BD (RDS compartida por el equipo), API de
#  legacy-backend y el MS de pre-aprobaciones reales. El front corre LOCAL.
#  AUTOSUFICIENTE: ya no existe playground/env — todo lo de dev vive en este archivo.
#  Gitignoreado (trae secretos). La plantilla documentada es .env.dev.example.
#  Prioridad de lectura: process.env > este archivo.
# ----------------------------------------------------------------------------
#  ⚠ La guarda de ESCRITURA a la BD compartida NO vive acá a propósito (F-53):
#    exportá  I_KNOW_THIS_TOUCHES_SHARED_DEV=1  a mano en la shell SOLO cuando
#    realmente quieras escribir a dev. El panel ya lo inyecta para sus corridas.

# ── Base de datos · RDS de dev (COMPARTIDA — cuidado al escribir) ──
# host del RDS de dev
E2E_DB_HOST=
# puerto MySQL
E2E_DB_PORT=
# schema
E2E_DB_NAME=
# credenciales del RDS de dev
E2E_DB_USER=
E2E_DB_PASS=

# ── API + cripto ──
# base de la API de legacy-backend en dev
E2E_API_BASE_URL=
# clave Laravel para (des)encriptar la fila Experian — debe ser la de dev
APP_KEY=

# ── Frontend ──
# wizard: en dev corre LOCAL (localhost:5174) contra el backend de dev
E2E_BASE_URL=

# ── Onboarding / flujo ──
# hash de sucursal por defecto de las corridas
E2E_PARTNER_HASH=
# MS Go de pre-aprobaciones (real en dev)
E2E_PREAPPROVALS_ENDPOINT=
# 1 = usa el MS real de pre-aprobados (no el mock). En dev va 1
E2E_REAL_PREAPPROVALS=
# destino de la notificación de cierre al comercio
E2E_WEBHOOK_URL=

# ── Cognito · pool de DEV ──
# Cuenta de dev = a.arismendy (única en el pool de dev hoy). USER/PASS vacíos
# → caen a .cognito.json. miguel-test AÚN NO existe en el pool de dev (falta Oscar).
# Hosted UI del pool de dev
E2E_COGNITO_DOMAIN=
# app-client del pool de dev (vacío → default del código)
E2E_COGNITO_CLIENT_ID=
E2E_COGNITO_CLIENT_SECRET=
# callback registrado del front local
E2E_COGNITO_REDIRECT=
E2E_COGNITO_SCOPE=
# vacío → usa .cognito.json (a.arismendy)
E2E_COGNITO_USER=
E2E_COGNITO_PASS=
