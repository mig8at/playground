#!/usr/bin/env bash
# Mock del MDM / merchant-gateway (device-locking) → desbloquea el enrolamiento de IMEI del canal SmartPay.
# Sin esto, MERCHANT_GATEWAYS_HOST apunta a `https://merchant-gateways.fake` y el escaneo del IMEI se traba
# justo antes del desembolso.
#
# Apuntá el backend con MERCHANT_GATEWAYS_HOST=http://host.docker.internal:$PORT en legacy-backend/.env
# (host.docker.internal, NO localhost: el backend corre en Docker).
#
# uso: bin/mock-mdm [start|stop|status|logs]
#   env: MOCK_MDM_PORT (8098) · MOCK_MDM_EMPTY=1 → simula "No se encontró el IMEI" (devices: [])
set -euo pipefail
DIR="$(cd "$(dirname "$0")/.." && pwd)"
PORT="${MOCK_MDM_PORT:-8098}"
LOG=/tmp/mock-mdm.log

up() { curl -s -o /dev/null --max-time 2 "http://localhost:$PORT" 2>/dev/null; }

case "${1:-start}" in
  start)
    WANT_EMPTY="${MOCK_MDM_EMPTY:-0}"
    if up; then
      CUR="$(curl -s --max-time 2 "http://localhost:$PORT" 2>/dev/null | node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>{try{process.stdout.write(JSON.parse(s).empty?"1":"0")}catch{process.stdout.write("0")}})')"
      if [ "${CUR:-0}" = "$WANT_EMPTY" ]; then echo "✓ mock-mdm ya arriba (:$PORT)"; exit 0; fi
      echo "↻ reinicio mock-mdm (modo IMEI-no-encontrado: ${CUR:-0} → $WANT_EMPTY)"
      lsof -ti:"$PORT" 2>/dev/null | xargs kill -9 2>/dev/null || true
      for _ in $(seq 1 10); do up || break; sleep 0.2; done
    fi
    rm -f "$LOG"
    nohup env MOCK_MDM_PORT="$PORT" MOCK_MDM_EMPTY="$WANT_EMPTY" \
      node "$DIR/mock-mdm/server.mjs" < /dev/null > "$LOG" 2>&1 &
    for _ in $(seq 1 25); do up && { echo "✓ mock-mdm :$PORT (device-locking)"; exit 0; }; sleep 0.3; done
    echo "✗ no levantó"; tail -8 "$LOG" 2>/dev/null; exit 1;;
  stop)
    lsof -ti:"$PORT" 2>/dev/null | xargs kill -9 2>/dev/null && echo "⏹ detenido (:$PORT)" || echo "no estaba corriendo";;
  status)
    if up; then curl -s --max-time 2 "http://localhost:$PORT" 2>/dev/null; echo ""; else echo "○ off (:$PORT)"; fi;;
  logs)
    tail -n "${2:-40}" "$LOG" 2>/dev/null || echo "(sin log)";;
  *)
    echo "uso: bin/mock-mdm [start|stop|status|logs]";;
esac
