#!/usr/bin/env bash
# Mock de ÁBACO: el proveedor EXTERNO que valida ingresos de plataformas gig (Uber/Didi/Rappi…).
# Lo pide el flujo de RENTING (lenders con `product='renting'`, ej. Motai R) después de elegir entidad.
# No tenemos su código: es 100% externo. Cubre `init/gig-economy` y `login`; `/results` y `/platforms`
# ya los resuelve el propio backend en local (fixture + setting), así que no salen a la red.
#
# Apuntá el backend en legacy-backend/.env (host.docker.internal, NO localhost — corre en Docker):
#   ABACO_HOST=http://host.docker.internal:8102
#   ABACO_SCRAPING_PREFIX=/mock
# (con ABACO_HOST=http://localhost el backend se pega a SÍ MISMO → `ABAC2004 Error initializing`)
#
# uso: bin/mock-abaco [start|stop|status|logs]
#   env: MOCK_ABACO_PORT (8102) · MOCK_ABACO_FAIL=1 → responde 500 (probar el camino de error)
set -euo pipefail
DIR="$(cd "$(dirname "$0")/.." && pwd)"
PORT="${MOCK_ABACO_PORT:-8102}"
LOG=/tmp/mock-abaco.log

up() { curl -s -o /dev/null --max-time 2 "http://localhost:$PORT" 2>/dev/null; }

case "${1:-start}" in
  start)
    WANT_FAIL="${MOCK_ABACO_FAIL:-0}"
    if up; then
      CUR="$(curl -s --max-time 2 "http://localhost:$PORT" 2>/dev/null | node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>{try{process.stdout.write(JSON.parse(s).fail?"1":"0")}catch{process.stdout.write("0")}})')"
      if [ "${CUR:-0}" = "$WANT_FAIL" ]; then echo "✓ mock-abaco ya arriba (:$PORT)"; exit 0; fi
      echo "↻ reinicio mock-abaco (modo fallo: ${CUR:-0} → $WANT_FAIL)"
      lsof -ti:"$PORT" 2>/dev/null | xargs kill -9 2>/dev/null || true
      for _ in $(seq 1 10); do up || break; sleep 0.2; done
    fi
    rm -f "$LOG"
    nohup env MOCK_ABACO_PORT="$PORT" MOCK_ABACO_FAIL="$WANT_FAIL" \
      node "$DIR/mock-abaco/server.mjs" < /dev/null > "$LOG" 2>&1 &
    for _ in $(seq 1 25); do up && { echo "✓ mock-abaco :$PORT"; exit 0; }; sleep 0.3; done
    echo "✗ no levantó"; tail -8 "$LOG" 2>/dev/null; exit 1;;
  stop)
    lsof -ti:"$PORT" 2>/dev/null | xargs kill -9 2>/dev/null && echo "⏹ detenido (:$PORT)" || echo "no estaba corriendo";;
  status)
    if up; then curl -s --max-time 2 "http://localhost:$PORT" 2>/dev/null; echo ""; else echo "○ off (:$PORT)"; fi;;
  logs)
    tail -n "${2:-40}" "$LOG" 2>/dev/null || echo "(sin log)";;
  *)
    echo "uso: bin/mock-abaco [start|stop|status|logs]";;
esac
