#!/usr/bin/env bash
# Mock del pdf-mapper-service (genera los documentos SIN plantilla Blade, ej. `vinculacion` de Credifamilia).
# vinculacion es microservice POR DISENO (sin fallback Blade) → sin este mock, Credifamilia no cierra.

#
# Apuntá el backend en legacy-backend/.env (host.docker.internal, NO localhost — corre en Docker):
#   PDF_MAPPER_BASE_URL=http://host.docker.internal:8100  (idem PDF_MAPPER_SERVICE_HOST)
#
# uso: bin/mock-pdf-mapper [start|stop|status|logs]
#   env: MOCK_PDFMAP_PORT (8100) · MOCK_PDFMAP_FAIL=1 → responde 500 (probar el camino de error)
set -euo pipefail
DIR="$(cd "$(dirname "$0")/.." && pwd)"
PORT="${MOCK_PDFMAP_PORT:-8100}"
LOG=/tmp/mock-pdf-mapper.log

up() { curl -s -o /dev/null --max-time 2 "http://localhost:$PORT" 2>/dev/null; }

case "${1:-start}" in
  start)
    WANT_FAIL="${MOCK_PDFMAP_FAIL:-0}"
    if up; then
      CUR="$(curl -s --max-time 2 "http://localhost:$PORT" 2>/dev/null | node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>{try{process.stdout.write(JSON.parse(s).fail?"1":"0")}catch{process.stdout.write("0")}})')"
      if [ "${CUR:-0}" = "$WANT_FAIL" ]; then echo "✓ mock-pdf-mapper ya arriba (:$PORT)"; exit 0; fi
      echo "↻ reinicio mock-pdf-mapper (modo fallo: ${CUR:-0} → $WANT_FAIL)"
      lsof -ti:"$PORT" 2>/dev/null | xargs kill -9 2>/dev/null || true
      for _ in $(seq 1 10); do up || break; sleep 0.2; done
    fi
    rm -f "$LOG"
    nohup env MOCK_PDFMAP_PORT="$PORT" MOCK_PDFMAP_FAIL="$WANT_FAIL" \
      node "$DIR/mock-pdf-mapper/server.mjs" < /dev/null > "$LOG" 2>&1 &
    for _ in $(seq 1 25); do up && { echo "✓ mock-pdf-mapper :$PORT"; exit 0; }; sleep 0.3; done
    echo "✗ no levantó"; tail -8 "$LOG" 2>/dev/null; exit 1;;
  stop)
    lsof -ti:"$PORT" 2>/dev/null | xargs kill -9 2>/dev/null && echo "⏹ detenido (:$PORT)" || echo "no estaba corriendo";;
  status)
    if up; then curl -s --max-time 2 "http://localhost:$PORT" 2>/dev/null; echo ""; else echo "○ off (:$PORT)"; fi;;
  logs)
    tail -n "${2:-40}" "$LOG" 2>/dev/null || echo "(sin log)";;
  *)
    echo "uso: bin/mock-pdf-mapper [start|stop|status|logs]";;
esac
