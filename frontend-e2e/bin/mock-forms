#!/usr/bin/env bash
# Mock del ONBOARDING-FORMS-SERVICE: sirve el SCHEMA del flujo DINÁMICO (comercios de RD, ej. CeluRD
# /SmartPay, que entran por `/request-amount` en vez de `/solicitar`). Sin esto el wizard muestra
# "Formulario no encontrado": el host real necesita VPN y los schemas viven en S3.
#
# Apuntá el WIZARD (no el backend) en frontend-monorepo, .env.local del loan-request-wizard:
#   VITE_ONBOARDING_FORM_SERVICE=http://localhost:8101
#
# Si dejás un schema real en `mock-forms/schemas/<form_id>.json` se sirve ESE; si no, uno genérico
# válido. Ver la cabecera de `mock-forms/server.mjs` para el detalle.
#
# uso: bin/mock-forms [start|stop|status|logs]
#   env: MOCK_FORMS_PORT (8101) · MOCK_FORMS_UNUSED=1 → responde 500 (probar el camino de error)
set -euo pipefail
DIR="$(cd "$(dirname "$0")/.." && pwd)"
PORT="${MOCK_FORMS_PORT:-8101}"
LOG=/tmp/mock-forms.log

up() { curl -s -o /dev/null --max-time 2 "http://localhost:$PORT" 2>/dev/null; }

case "${1:-start}" in
  start)
    WANT_FAIL="${MOCK_FORMS_UNUSED:-0}"
    if up; then
      CUR="$(curl -s --max-time 2 "http://localhost:$PORT" 2>/dev/null | node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>{try{process.stdout.write(JSON.parse(s).fail?"1":"0")}catch{process.stdout.write("0")}})')"
      if [ "${CUR:-0}" = "$WANT_FAIL" ]; then echo "✓ mock-forms ya arriba (:$PORT)"; exit 0; fi
      echo "↻ reinicio mock-forms (modo fallo: ${CUR:-0} → $WANT_FAIL)"
      lsof -ti:"$PORT" 2>/dev/null | xargs kill -9 2>/dev/null || true
      for _ in $(seq 1 10); do up || break; sleep 0.2; done
    fi
    rm -f "$LOG"
    nohup env MOCK_FORMS_PORT="$PORT" E2E_TARGET="${E2E_TARGET:-local}" \
      node "$DIR/mock-forms/server.mjs" < /dev/null > "$LOG" 2>&1 &
    for _ in $(seq 1 25); do up && { echo "✓ mock-forms :$PORT"; exit 0; }; sleep 0.3; done
    echo "✗ no levantó"; tail -8 "$LOG" 2>/dev/null; exit 1;;
  stop)
    lsof -ti:"$PORT" 2>/dev/null | xargs kill -9 2>/dev/null && echo "⏹ detenido (:$PORT)" || echo "no estaba corriendo";;
  status)
    if up; then curl -s --max-time 2 "http://localhost:$PORT" 2>/dev/null; echo ""; else echo "○ off (:$PORT)"; fi;;
  logs)
    tail -n "${2:-40}" "$LOG" 2>/dev/null || echo "(sin log)";;
  *)
    echo "uso: bin/mock-forms [start|stop|status|logs]";;
esac
