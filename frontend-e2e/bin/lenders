#!/usr/bin/env bash
# lenders — lista los lenders de un comercio a NIVEL SUCURSAL (lenders_by_allied_branches) con su
# response_type — igual que la VISIBILIDAD real del wizard (resolveLenderIdsByBranch), antes de reglas.
# Read-only contra dev (E2E_TARGET=dev por defecto). Para inspección rápida sin entrar al menú.
#   lenders <comercio>        comercio = key de .flows.json (pullman, sonria, …) o nombre/slug en dev
#   lenders                   (sin arg) lista los comercios de .flows.json
set -euo pipefail
E2E="$(cd "$(dirname "$0")/.." && pwd)"; cd "$E2E"
FLOWS="$E2E/.flows.json"
export E2E_TARGET="${E2E_TARGET:-dev}"

M="${1:-}"
if [ -z "$M" ]; then
  echo "uso: lenders <comercio>   ·   comercios en .flows.json:"
  node -e 'try{const j=JSON.parse(require("fs").readFileSync(process.argv[1]));console.log("  "+Object.keys(j.merchants||{}).sort().join(", "))}catch(e){}' "$FLOWS"
  exit 0
fi

# hash: de .flows.json (key) o resuelto en dev (nombre/slug)
HASH="$(node -e 'try{const j=JSON.parse(require("fs").readFileSync(process.argv[1]));process.stdout.write((j.merchants&&j.merchants[process.argv[2]]&&j.merchants[process.argv[2]].branch_hash)||"")}catch(e){}' "$FLOWS" "$M")"
if [ -z "$HASH" ]; then
  HASH="$(node bin/dbops.ts list "$M" 2>/dev/null | node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>{try{const j=JSON.parse(s);process.stdout.write((j[0]&&j[0].hash)||"")}catch(e){}})')"
fi
[ -n "$HASH" ] || { echo "✗ no resolví el comercio '$M' (probá: node bin/dbops.ts list $M)"; exit 1; }

echo "▶ lenders de '$M' ($HASH) — nivel SUCURSAL (lenders_by_allied_branches), = visibilidad del wizard:"
node bin/dbops.ts lenders-for "$HASH" 2>/dev/null | node -e '
let s="";process.stdin.on("data",d=>s+=d).on("end",()=>{
  try{
    const a=JSON.parse(s);
    if(!Array.isArray(a)||!a.length){console.log("  (ninguno — ¿VPN? ¿sucursal sin lenders?)");return;}
    const tag=rt=>rt===2?"Creditop X (rt=2) · in-platform":rt===1?"integración (rt=1) · API externa":rt===0?"estándar/agregador (rt=0) · handoff":rt===3?"revolving (rt=3)":rt===4?"externo-gestionado (rt=4)":("rt="+rt);
    for(const l of a){ const off=Number(l.branch_status)!==1?"  [deshabilitado en sucursal]":""; console.log("  #"+String(l.id).padEnd(4)+" "+String(l.name).padEnd(36)+" "+tag(l.rt)+off); }
    console.log("  — "+a.length+" lender(s) · ojo: esto es PRE-reglas (group rules/datacrédito/modo refinan después)");
  }catch(e){console.log("  (error parseando)",String(s).slice(0,160))}
})'
