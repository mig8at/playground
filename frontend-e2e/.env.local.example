# ============================================================================
#  frontend-e2e · TARGET=local   (E2E_TARGET=local)
# ============================================================================
#  Todo local/mockeado: BD y backend en Docker, externos por mocks. No toca nada
#  compartido. AUTOSUFICIENTE. Gitignoreado. Plantilla: .env.local.example.

# ── Base de datos · Docker local ──
# 127.0.0.1 (contenedor MySQL local)
E2E_DB_HOST=
E2E_DB_PORT=
E2E_DB_NAME=
E2E_DB_USER=
E2E_DB_PASS=
# nombres de contenedor (los usa dbops/sail)
E2E_DB_CONTAINER=
E2E_APP_CONTAINER=

# ── API + cripto ──
E2E_API_BASE_URL=
# APP_KEY local (des/encripta Experian)
APP_KEY=

# ── Frontend + mocks ──
# wizard local
E2E_BASE_URL=
# base de los mocks locales
E2E_MOCK_URL=

# ── Flujo ──
E2E_PARTNER_HASH=
# asesor | ecommerce
E2E_CHANNEL=
# monto por defecto de la solicitud
E2E_AMOUNT=
# puerto del mock-store (ecommerce)
E2E_SHOP_PORT=
E2E_WEBHOOK_URL=
