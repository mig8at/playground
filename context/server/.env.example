# Conexión Jira (Atlassian Cloud) — CABLEADA en el server de Context para el
# futuro sync de tareas de los workspaces con issues/ramas. Mismas variables que
# usan los conectores de playground/tools. Copiá este archivo a `.env` y completá.
# El .env NO se commitea (ver .gitignore).

ATLASSIAN_SITE=https://tuempresa.atlassian.net
ATLASSIAN_EMAIL=tu-email@empresa.com
ATLASSIAN_API_TOKEN=tu_api_token   # id.atlassian.com/manage-profile/security/api-tokens

# opcional (para el futuro sync): tablero del sprint activo
# JIRA_BOARD_ID=384
