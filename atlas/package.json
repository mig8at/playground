{
  "name": "creditop-atlas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,web -c green,cyan \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "cd server && go run ./cmd/web",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server:build": "cd server && go build -o bin/web ./cmd/web && go build -o bin/atlas-mcp ./cmd/atlas-mcp",
    "server:mcp": "cd server && go run ./cmd/atlas-mcp"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.0",
    "vite": "^6.0.7"
  }
}
