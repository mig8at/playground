 {
  "key": "identityVerification",
  "name": "IdentityVerification",
  "tipo": "aggregateRoot",
  "estado": "mapeada_ok",
  "descripcion": "La verificación de identidad de un solicitante a lo largo de su solicitud de crédito, que unifica las distintas validaciones de KYC, biometría y firma realizadas con proveedores externos. Concentra el resultado y la evidencia de cada validación para determinar si la persona es quien dice ser y puede continuar.",
  "legacy": {
   "tabla": "validations",
   "absorbe": [
    "jumio_accounts",
    "crosscore_evaluations",
    "netco_signing_documents"
   ],
   "unificacion": "Antes cada proveedor de verificación tenía su propia tabla (Jumio, CrossCore, Netco). Se unifican porque todos cumplen la misma función de negocio —comprobar la identidad del cliente—, de modo que cada verificación queda como un único registro, sin importar qué proveedor la realice."
  },
  "atributos": [
   {
    "n": "id",
    "t": "bigint",
    "legacy": null
   },
   {
    "n": "provider",
    "t": "ref(Provider)",
    "legacy": null
   },
   {
    "n": "evidence",
    "t": "json",
    "legacy": null
   },
   {
    "n": "external_ref",
    "t": "varchar(255)",
    "legacy": null
   },
   {
    "n": "customer_id",
    "t": "bigint",
